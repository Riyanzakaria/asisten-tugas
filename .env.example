# ============================================================
#  PAIA - Environment Variables Template
#  Salin file ini menjadi ".env" untuk development lokal
#  JANGAN commit file ".env" ke Git! (sudah ada di .gitignore)
# ============================================================

# Google Gemini API Key
# Dapatkan di: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram Bot Token
# Dapatkan dari @BotFather di Telegram dengan perintah /newbot
TELEGRAM_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# Telegram Chat ID (bisa Personal ID atau Group ID)
# Cara dapat: kirim pesan ke bot, lalu buka
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=123456789

# Edlink Token (SATU token untuk semua keperluan Edlink)
# Token ini bersifat ganda:
#   1. Dipakai sebagai Bearer token untuk API weekly-schedules
#   2. Dipakai sebagai parameter ?token=... di URL SSO login
# Cara dapat: Login edlink.id > F12 > Application > Local Storage > key 'token'
EDLINK_TOKEN=your_edlink_token_here

# Edlink Login Credentials (untuk scraping pengumuman/tugas via SSO)
EDLINK_EMAIL=your_email@example.com
EDLINK_PASSWORD=your_edlink_password_here

# Notion API Credentials
# Dapatkan API key di https://www.notion.so/my-integrations
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxx
# Dapatkan Database ID dari URL database Notion kamu
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
